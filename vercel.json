{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "dataquard.ch"
        }
      ],
      "destination": "https://www.dataquard.ch/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/compliance-report",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/admin-digest",
      "schedule": "30 7 * * 1"
    },
    {
      "path": "/api/cron/subscription-reminder",
      "schedule": "0 8 * * *"
    }
  ]
}
