{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "dataquard.ch"
        }
      ],
      "destination": "https://www.dataquard.ch/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/compliance-report",
      "schedule": "0 7 * * 1"
    }
  ]
}
